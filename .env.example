# Echo Demo · 后端环境变量样板（dev / demo 通用）
# 复制本文件为 `.env`，把所有标 ⚠️ 必填 的密钥换成真值
# 真实密钥**永远不入仓**，仅 `.env.example` 入仓

# ── Server ─────────────────────────────────────────────────────────
# canonical port = 8769（P1.1 Phase 1 统一）。Electron main.cjs / runtime.ts /
# vite.config / playwright / install-backend.sh 全部对齐这个值；改前确认全改。
PORT=8769
LOG_LEVEL=INFO

# ── Public endpoints（desktop bootstrap 时拉取）─────────────────────
PUBLIC_WS_URL=ws://localhost:8769/ws/echo
PUBLIC_HTTP_URL=http://localhost:8769
APP_VERSION=0.2.24

# ── LLM 主通道（用户 2026-05-26 决策：demo 期走 Yunwu，5090 self-host 修好再切）
# yunwu-open-key：本地开发时填入自己的 key，真实密钥不要提交
LLM_MAIN_PROVIDER=yunwu
LLM_MAIN_MODEL=MiniMax-M2.7
LLM_MAIN_BASE_URL=https://yunwu.ai/v1
YUNWU_OPEN_KEY=

# 备用模型（Yunwu 一站式，按 token 计费）— Yunwu M2.7 限速时切
LLM_FALLBACK_1=GLM-4.6
LLM_FALLBACK_2=Kimi-K2.6

# ── LLM 快速通道（路由/extract/简短直答/nano）
# qwen3.5-9b-local-gpu0 在 eight :7860 已稳定运行（vLLM），IP=100.76.3.59（tailnet）
LLM_FAST_PROVIDER=eight-local
LLM_FAST_MODEL=qwen3.5-9b-local-gpu0
# eight Tailscale endpoint（2026-06-18：STT/TTS/Fast LLM 已迁到 eight）
LLM_FAST_BASE_URL=http://100.76.3.59:7860/v1
LLM_LOCAL_API_KEY=EMPTY

# 长任务/复杂思考 max_tokens（v6.7.1 决策）
LLM_MAIN_MAX_TOKENS=80000
LLM_FAST_MAX_TOKENS=512

# ── STT（语音转文字）────────────────────────────────────────────────
# 唯一通道：firered → FireRedASR2-AED @ eight :8090（判别式无幻觉、中文强）
# SenseVoice GPU :8093 在 PR `echodesk-remove-sensevoice` 删除，原因：多 backend
# 选项老让人误判"换 STT 能修 X"——实际 ambient 幻觉 / speaker explosion 全是
# ambient_capture + diarizer 链路问题，跟 STT 模型无关。
# 详见 docs/ARCH-AUDIT.md §2
STT_BACKEND=firered
# eight Tailscale endpoint（2026-06-18：STT/TTS/Fast LLM 已迁到 eight）
STT_FIRERED_URL=http://100.76.3.59:8090
STT_LANGUAGE=zh
STT_LLM_CORRECT=false

# ── TTS（文字转语音）────────────────────────────────────────────────
# 主：faster-qwen3-tts 1.7B CustomVoice @ eight :8094（TTFA < 500ms）
# 备：openai → yunwu gpt-4o-mini-tts
# 命名校正（2026-05-27）：旧 TTS_COSYVOICE_* env 仍兼容；新代码用 TTS_QWEN3_*
# 详见 docs/ARCH-AUDIT.md §3
TTS_ENABLED=true
TTS_PROVIDER=qwen3_tts
# eight Tailscale endpoint（2026-06-18：STT/TTS/Fast LLM 已迁到 eight）
TTS_QWEN3_URL=http://100.76.3.59:8094
TTS_QWEN3_VOICE=aiden

# ── Speaker Diarization（声纹）─────────────────────────────────────
# backend=ecapa：SpeechBrain ECAPA-TDNN（首次下载 85MB 到 .cache/speechbrain）
# 阈值 0.65（spike 2026-05-25 §6.15-6.16: ECAPA 6 人混合 DER=0.0%）
DIARIZER_ENABLED=true
DIARIZER_BACKEND=ecapa
DIARIZER_MATCH_THRESHOLD=0.65
DIARIZER_MIN_AUDIO_BYTES=16000

# ── Ambient 预过滤 / 幻觉门控（echodesk-spk-4 2026-05-27 收紧默认）─────
# 默认值见 backend/app/config.py，echo 基线 (600/400/0.05/12/4) → 收紧到 (800/500/0.15/10/5)。
# 收紧依据：docs/ARCH-AUDIT.md §4 root #7。
# 仅当本地需要回退到 echo 基线测试（如真实回归 audio）时，取消注释下面五行：
# AMBIENT_RMS_GATE=600
# AMBIENT_FRAME_RMS_THRESHOLD=400
# AMBIENT_MIN_SPEECH_FRAME_RATIO=0.05
# AMBIENT_MAX_CPS=12.0
# AMBIENT_MIN_STT_CHARS=4

# ── RAG（jieba + BM25 多文档+会议）─────────────────────────────────
RAG_INDEX_DIR=~/.echodesk/rag_index
RAG_TOP_K=5
RAG_PDF_CHUNK_TOKENS=600
RAG_PDF_CHUNK_OVERLAP=100

# ── 授权工作区（M6：可选；空 = 关闭）─────────────────────────────
# 配置一个或多个目录，启动时自动扫描入库；增量按 mtime+size+hash
# 多目录用逗号分隔；支持 ~ 展开
# WORKSPACE_DIRS=~/Documents/work-materials,~/Notes
WORKSPACE_DIRS=
WORKSPACE_MAX_FILE_MB=20
WORKSPACE_SCAN_ON_STARTUP=true
WORKSPACE_STATE_FILE=~/.echodesk/workspace_state.json
UPLOAD_MAX_FILE_MB=50

# ── Web Search（Tavily 主 + DDG 兜底，2026-05-26 17:38 用户决策）─────
# 用户："就用tavily，别用inspiro了"
WEB_SEARCH_ENABLED=true
WEB_SEARCH_TOP_N=5
TAVILY_API_KEY=
WEB_ARBITRATION_MODEL=qwen3.5-9b-local-gpu0
# 仲裁器对 RAG vs Web 两个结果做置信度打分（fabrication_guard + pre_classifier）

# ── Skill 执行器（PPT / Word / Excel / HTML，4 个产物）
# 复用 echo/experiments/2026-05-26_anthropic_skill_quality/ v6.7.1 验证的 prompt+toolchain
SKILL_PPT_TOOL=pptxgenjs                        # npm install -g pptxgenjs
SKILL_WORD_TOOL=python-docx                     # pip install python-docx
SKILL_XLSX_TOOL=openpyxl                        # pip install openpyxl
SKILL_XLSX_RECALC=libreoffice                   # 需要 LibreOffice headless
SKILL_HTML_TOOL=single-file-tailwind-cdn
SKILL_FIX_MAX_RETRIES=3                         # iterative fix loop 上限
SKILL_NODE_BIN=node                             # which node

# ── Database ───────────────────────────────────────────────────────
DB_PATH=~/.echodesk/echodesk.db
STORAGE_DIR=~/.echodesk/storage

# ── Security ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=app://.,http://localhost:5173,http://localhost:8769
PUBLIC_DEMO_MODE=false
DEBUG_TOKEN=                                    # ⚠️ 可选 (admin endpoints)
