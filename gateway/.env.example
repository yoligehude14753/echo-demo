# ===== echo-gateway 运行配置（真实凭证只放服务端，切勿提交真值）=====

# 服务
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# 发给外部客户端的 token 白名单（逗号分隔）。生成：openssl rand -hex 24
# 空 = fail-closed 拒绝所有请求
ECHO_GW_TOKENS=replace-with-client-token-1,replace-with-client-token-2

# 每 token 限流：window_s 内最多 max_requests 次
RATE_LIMIT_WINDOW_S=60
RATE_LIMIT_MAX_REQUESTS=120

# ── 上游：主 LLM（yunwu） ──
YUNWU_BASE_URL=https://yunwu.ai/v1
YUNWU_OPEN_KEY=sk-replace-with-real-yunwu-key
YUNWU_MODELS=MiniMax-M2.7,GLM-4.6,Kimi-K2.6

# ── 上游：fast LLM（heyi-bj） ──
HEYI_FAST_BASE_URL=https://llm-fast.yoliyoli.uk/v1
HEYI_FAST_KEY=EMPTY

# ── 上游：STT（FireRed，不含 /v1） ──
HEYI_STT_BASE_URL=https://stt.yoliyoli.uk

# ── 上游：TTS（Qwen3-TTS，不含 /v1） ──
HEYI_TTS_BASE_URL=https://tts.yoliyoli.uk

# 超时
UPSTREAM_TIMEOUT_S=120
UPSTREAM_CONNECT_TIMEOUT_S=10

# CORS：客户端 Electron 用 app://，可填 * 或具体来源逗号分隔
ALLOWED_ORIGINS=*
